<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.armada.account.mapper.AccountCredentialMapper">

  <!-- 时间列为 BIGINT,无 DB 默认值;insert 须显式写入 created_at/updated_at。tenant_id 由拦截器注入。 -->
  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO account_credential (
      account_id, ws_phone, cred_format, creds_json,
      created_at, updated_at
    ) VALUES (
      #{accountId}, #{wsPhone}, #{credFormat}, #{credsJson},
      #{createdAt}, #{updatedAt}
    )
  </insert>

  <!-- deleted_at IS NULL 等价于 is_active=1(虚拟列) -->
  <select id="selectByAccountId" resultType="com.armada.account.model.entity.AccountCredential">
    SELECT * FROM account_credential
    WHERE account_id = #{accountId}
      AND deleted_at IS NULL
    LIMIT 1
  </select>

	  <select id="selectByAccountIds" resultType="com.armada.account.model.entity.AccountCredential">
	    <if test="accountIds != null and accountIds.size() &gt; 0">
	    SELECT * FROM account_credential
	    WHERE deleted_at IS NULL
	      AND account_id IN
    <foreach collection="accountIds" item="i" open="(" separator="," close=")">#{i}</foreach>
    </if>
    <if test="accountIds == null or accountIds.size() == 0">
	    SELECT * FROM account_credential WHERE 1=0
	    </if>
	  </select>

	  <select id="selectByTenantAndAccountIds" resultType="com.armada.account.model.entity.AccountCredential">
	    <if test="accountIds != null and accountIds.size() &gt; 0">
	    SELECT * FROM account_credential
	    WHERE tenant_id = #{tenantId}
	      AND deleted_at IS NULL
	      AND account_id IN
	    <foreach collection="accountIds" item="i" open="(" separator="," close=")">#{i}</foreach>
	    </if>
	    <if test="accountIds == null or accountIds.size() == 0">
	    SELECT * FROM account_credential WHERE 1=0
	    </if>
	  </select>

</mapper>
