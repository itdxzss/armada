# Armada staging deployment env.
# Copy this file to /home/app/armada-deploy/.env on the test server and fill real values there.
# deploy-test.sh syncs this example but never overwrites the real .env.

ARMADA_HTTP_PORT=18080

DB_URL=jdbc:mysql://REPLACE_RDS_ENDPOINT:3306/armada?useSSL=false&serverTimezone=UTC
DB_USER=REPLACE_DB_USER
DB_PASSWORD=REPLACE_DB_PASSWORD

DEV_LOGIN_PASSWORD=armada123
JAVA_TOOL_OPTIONS=-Xms1024m -Xmx1024m

# Kafka consume + command dispatch.
SPRING_PROFILES_ACTIVE=kafka
KAFKA_BOOTSTRAP_SERVERS=REPLACE_KAFKA_BROKERS
SPRING_KAFKA_PROPERTIES_SECURITY_PROTOCOL=SSL
PROTOCOL_ACCOUNT_COMMANDS_TOPIC=armada.protocol.account.commands.v1
PROTOCOL_MASTER_COMMANDS_TOPIC=armada.protocol.master.commands.v1
PROTOCOL_ACCOUNT_EVENTS_TOPIC=armada.protocol.account.events.v1
PROTOCOL_GROUP_EVENTS_TOPIC=armada.protocol.group.events.v1
PROTOCOL_ACCOUNT_EVENTS_GROUP_ID=armada-api-account-events
PROTOCOL_GROUP_EVENTS_GROUP_ID=armada-api-group-events
PROTOCOL_COMMAND_DISPATCH_IMMEDIATE_ENABLED=true
PROTOCOL_COMMAND_DISPATCH_SCHEDULER_ENABLED=true
ACCOUNT_IMPORT_ONLINE_DISPATCH_SCHEDULER_ENABLED=true
